# .NET
bin/
obj/
*.user
*.suo
.vs/
.vscode/settings.json
*.DotSettings.user

# Build output
publish/

# NuGet
*.nupkg
.nuget/

# Rider
.idea/

# Python plugin environments
plugins/**/venv/
plugins/**/.venv/
plugins/**/__pycache__/
plugins/**/*.pyc
plugins/**/*.pyo

# Learning tools venv
learning/tools/.venv/
learning/tools/__pycache__/

# Local config overrides (never commit secrets)
appsettings.local.json
appsettings.Development.local.json

# Ollama models (large, managed by Docker volume)
.ollama/

# Logs
logs/
*.log

# macOS
.DS_Store

# Thumbnails / cache (generated, not source)
.pikore-cache/

# Local dev workdir — databases, scratch files, test data; keep the directory tracked
workdir/*
!workdir/.gitkeep
